execute if score .mode mode matches 4..5 unless items entity @s weapon.offhand totem_of_undying run return run item replace entity @s weapon.offhand with totem_of_undying
execute if score .shield toggles matches 0 unless items entity @s weapon.offhand totem_of_undying run return run item replace entity @s weapon.offhand with totem_of_undying
execute if score .shield toggles matches 1 unless items entity @s weapon.offhand shield run item replace entity @s weapon.offhand with shield[death_protection={death_effects:[{type:"clear_all_effects"},{type:"apply_effects",effects:[{id:"minecraft:regeneration",amplifier:1,duration:900},{id:"minecraft:fire_resistance",amplifier:0,duration:800},{id:"minecraft:absorption",amplifier:1,duration:100}]}]},enchantments={unbreaking:3,mending:1},unbreakable={}]